{
    "openapi": "3.0.1",
    "info": {
        "title": "OpenAPI definition",
        "version": "v0"
    },
    "servers": [
        {
            "url": "http://localhost:8082",
            "description": "Generated server url"
        }
    ],
    "tags": [
        {
            "name": "Visits",
            "description": "The Visit Management API"
        }
    ],
    "paths": {
        "/api/visits/{visitId}": {
            "get": {
                "tags": [
                    "Visits"
                ],
                "summary": "Get a visit by ID",
                "description": "Returns a single visit by its ID or 404 if not found",
                "operationId": "getVisitById",
                "parameters": [
                    {
                        "name": "visitId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int32"
                        }
                    }
                ],
                "responses": {
                    "404": {
                        "description": "Visit not found",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/VisitResponseDTO"
                                }
                            }
                        }
                    },
                    "200": {
                        "description": "Visit found",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/VisitResponseDTO"
                                }
                            }
                        }
                    }
                }
            },
            "put": {
                "tags": [
                    "Visits"
                ],
                "summary": "Update an existing visit",
                "description": "Updates the description and date of an existing visit",
                "operationId": "updateVisit",
                "parameters": [
                    {
                        "name": "visitId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int32"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UpdateVisitRequestDTO"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Visit updated successfully",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/VisitResponseDTO"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Visit not found",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/VisitResponseDTO"
                                }
                            }
                        }
                    }
                }
            },
            "delete": {
                "tags": [
                    "Visits"
                ],
                "summary": "Delete a visit",
                "description": "Removes a visit by its ID",
                "operationId": "deleteVisit",
                "parameters": [
                    {
                        "name": "visitId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int32"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Visit deleted successfully"
                    },
                    "404": {
                        "description": "Visit not found"
                    }
                }
            }
        },
        "/api/visits": {
