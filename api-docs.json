                "responses": {
                    "200": {
                        "description": "Visits retrieved successfully",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/VisitResponseDTO"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
